db.sqlite3.pre-*
EnterpriseInvoice-*.pdf

# Sensitive / proprietary operational data — sync externally
.kitchen_ops/
Men's Wentworth Food Budget*.csv
OneDrive_*.zip

# Reference material (copyrighted published work)
The-Book-of-Yields*.pdf

# Claude Code personal workspace (hook scripts, snapshots, time log,
